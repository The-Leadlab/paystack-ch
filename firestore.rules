rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownerUid() {
      return request.auth.uid;
    }

    function resourceOwnedByUser() {
      return signedIn() && (
        resource.data.restaurantId == ownerUid() ||
        resource.data.restaurant_id == ownerUid() ||
        resource.data.userId == ownerUid() ||
        resource.data.uid == ownerUid()
      );
    }

    function createOwnedByUser() {
      return signedIn() && (
        request.resource.data.restaurantId == ownerUid() ||
        request.resource.data.restaurant_id == ownerUid() ||
        request.resource.data.userId == ownerUid() ||
        request.resource.data.uid == ownerUid()
      );
    }

    function resourceSessionOwnedByUser() {
      return signedIn() &&
        resource.data.session_id is string &&
        exists(/databases/$(database)/documents/sessions/$(resource.data.session_id)) &&
        (
          get(/databases/$(database)/documents/sessions/$(resource.data.session_id)).data.restaurantId == ownerUid() ||
          get(/databases/$(database)/documents/sessions/$(resource.data.session_id)).data.restaurant_id == ownerUid()
        );
    }

    function createSessionOwnedByUser() {
      return signedIn() &&
        request.resource.data.session_id is string &&
        exists(/databases/$(database)/documents/sessions/$(request.resource.data.session_id)) &&
        (
          get(/databases/$(database)/documents/sessions/$(request.resource.data.session_id)).data.restaurantId == ownerUid() ||
          get(/databases/$(database)/documents/sessions/$(request.resource.data.session_id)).data.restaurant_id == ownerUid()
        );
    }

    match /sessions/{id} {
      allow read, update, delete: if resourceOwnedByUser();
      allow create: if createOwnedByUser();
    }

    match /documents/{id} {
      allow read, update, delete: if resourceOwnedByUser() || resourceSessionOwnedByUser();
      allow create: if createOwnedByUser() || createSessionOwnedByUser();
    }

    match /income/{id} {
      allow read, update, delete: if resourceOwnedByUser();
      allow create: if createOwnedByUser();
    }

    match /expenses/{id} {
      allow read, update, delete: if resourceOwnedByUser();
      allow create: if createOwnedByUser();
    }

    match /pos_readings/{id} {
      allow read, update, delete: if resourceOwnedByUser();
      allow create: if createOwnedByUser();
    }

    match /employees/{id} {
      allow read, update, delete: if resourceOwnedByUser();
      allow create: if createOwnedByUser();
    }

    /** Billing mirror (Stripe webhooks via Admin SDK only — no client writes). */
    match /users/{userId} {
      allow read: if signedIn() && userId == ownerUid();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
