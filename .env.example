# =========================
# Client (Vite) variables
# =========================

# Gemini
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional client toggles
VITE_SUBSCRIPTION_ENABLED=true
# Comma-separated UIDs or emails that skip subscription enforcement (admin / legacy testers)
# VITE_SUBSCRIPTION_BYPASS_UIDS=firebaseUid1,firebaseUid2
VITE_SUBSCRIPTION_BYPASS_EMAILS=ali@the-leadlab.com,kara@the-leadlab.com
# VITE_API_BASE_URL=https://your-api-domain.com
# VITE_GEMINI_MODEL=gemini-2.5-flash
# VITE_GEMINI_BANK_MODEL=gemini-2.5-flash
# VITE_GEMINI_CHAT_MODEL=gemini-2.5-flash
# VITE_GEMINI_MAX_OUTPUT_TOKENS=8192
# VITE_DOCUMENT_PROCESSING_TIMEOUT_MS=240000
# VITE_DOCUMENT_PROCESSING_CONCURRENCY=3


# =========================
# Server variables (Stripe/API)
# =========================

PUBLIC_APP_URL=https://paystack.ch

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs from Dashboard → Products (e.g. price_1ABC...), not CHF amounts
STRIPE_PRICE_STARTER=price_xxx_starter
STRIPE_PRICE_BUSINESS=price_xxx_business
STRIPE_PRICE_UNLIMITED=price_xxx_unlimited
# STRIPE_TRIAL_DAYS=7
# STRIPE_CORS_ORIGIN=https://paystack.ch

# Firebase Admin service account JSON (single-line JSON string)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Local Stripe dev proxy (optional)
# STRIPE_DEV_PROXY=1
# STRIPE_DEV_PORT=8787
