rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Employees
    match /employees/{employeeId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.restaurantId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.restaurantId;
    }
    
    // Income
    match /income/{incomeId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.restaurantId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.restaurantId;
    }
    
    // Expenses
    match /expenses/{expenseId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.restaurantId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.restaurantId;
    }
    
    // Legacy clients collection (keep for backward compatibility)
    match /clients/{clientId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    // Temporary: allow all authenticated for testing
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
