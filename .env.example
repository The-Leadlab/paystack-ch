# =========================
# Client (Vite) variables
# =========================

# Gemini server-side only. Never expose this as VITE_*.
GEMINI_API_KEY=your_server_only_gemini_api_key_here
# Optional hardening controls
# GEMINI_ALLOWED_MODELS=gemini-2.5-flash,gemini-2.5-flash-image
# GEMINI_RATE_LIMIT_MAX=30
# GEMINI_MAX_REQUEST_BYTES=18874368

# Firebase Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
# If you use Firebase Analytics above, remove duplicate Google Analytics / GTM snippet from Vercel “Injection”
# to avoid loading gtag twice (hurts /app LCP).

# Optional client toggles
# Public origin for canonical URLs and Open Graph (no trailing slash). Defaults to https://www.paystack.ch
# VITE_PUBLIC_SITE_URL=https://www.paystack.ch
# Defer Google Tag Manager until after idle (improves LCP). If GTM is injected only in Vercel, move it here.
# VITE_GTM_ID=GTM-XXXXXXX
VITE_SUBSCRIPTION_ENABLED=true
# Stripe sandbox: all checkout / portal / link calls use test keys (no real charges). Rebuild after changing.
# VITE_STRIPE_USE_TEST=true
# Comma-separated UIDs or emails that skip subscription enforcement (admin / legacy testers)
# VITE_SUBSCRIPTION_BYPASS_UIDS=firebaseUid1,firebaseUid2
VITE_SUBSCRIPTION_BYPASS_EMAILS=ali@the-leadlab.com,kara@the-leadlab.com,joshua@the-leadlab.com
# Same host as the SPA: leave UNSET on paystack.ch (recommended).
# If set: origin ONLY — https://paystack.ch or https://www.paystack.ch (NOT /api, NOT /app).
# VITE_API_BASE_URL=https://paystack.ch
# Client model hints. The server allowlist still decides what is accepted.
# VITE_GEMINI_MODEL=gemini-2.5-flash
# VITE_GEMINI_BANK_MODEL=gemini-2.5-flash
# VITE_GEMINI_CHAT_MODEL=gemini-2.5-flash
# VITE_GEMINI_MAX_OUTPUT_TOKENS=8192
# VITE_DOCUMENT_PROCESSING_TIMEOUT_MS=600000
# Client wait per Gemini API call (ms); keep below server maxDuration in vercel.json (300s on Pro).
# VITE_GEMINI_FETCH_TIMEOUT_MS=292000
# VITE_DOCUMENT_PROCESSING_CONCURRENCY=3
# Large phone photos: auto-compress JPEG/PNG before Gemini (Vercel ~4.5 MB request cap).
# VITE_GEMINI_MAX_SOURCE_FILE_BYTES=20971520
# Storage uploads: no practical app cap (Firebase). AI analysis: ~50 MB/PDF (Google Gemini limit).
# GEMINI_MAX_ANALYSIS_BYTES=52428800
# VITE_GEMINI_MAX_PROXY_BODY_BYTES=4200000


# =========================
# Server variables (Stripe/API)
# =========================

PUBLIC_APP_URL=https://paystack.ch

# Operator panel at /admin (Edge middleware redirects here until cookie is set). POST /api/admin/verify compares this value (never expose in VITE_*).
ADMIN_ACCESS_PASSWORD=

# When true, guest checkout and APIs prefer Stripe test keys even if the client omits stripeTest.
# STRIPE_USE_TEST_MODE=true

STRIPE_SECRET_KEY=
# Signing secret(s) from Stripe Dashboard → Webhooks → your endpoint(s). Each URL has its own whsec_.
# If you listen on both https://paystack.ch/... and https://www.paystack.ch/..., paste BOTH secrets
# comma-separated below, OR put the second in STRIPE_WEBHOOK_SECRET_ALT.
STRIPE_WEBHOOK_SECRET=
# STRIPE_WEBHOOK_SECRET_ALT=
# Optional: Stripe test mode keys (guest JSON `stripeTest: true`, `/api/stripe-test/*` on the Node server).
# Use Stripe Dashboard (Test mode) prices: price_... IDs in STRIPE_TEST_PRICE_*.
STRIPE_TEST_SECRET_KEY=
# Same pattern as live: one secret per Stripe test webhook URL (comma-separated or use _ALT).
STRIPE_TEST_WEBHOOK_SECRET=
# STRIPE_TEST_WEBHOOK_SECRET_ALT=
STRIPE_TEST_PRICE_STARTER=
STRIPE_TEST_PRICE_BUSINESS=
STRIPE_TEST_PRICE_UNLIMITED=
# STRIPE_TEST_PRICE_ID=
# Stripe recurring prices. Prefer real Stripe Price IDs from Dashboard (price_1ABC...).
# Numeric CHF amounts are also supported and converted to monthly Checkout price_data.
STRIPE_PRICE_STARTER=29
STRIPE_PRICE_BUSINESS=59
STRIPE_PRICE_UNLIMITED=499
# STRIPE_TRIAL_DAYS=7
# STRIPE_CORS_ORIGIN=https://paystack.ch

# Optional duplicate of VITE_FIREBASE_API_KEY for server-only use. On Vercel you can skip this:
# link-checkout and /api/gemini already read process.env.VITE_FIREBASE_API_KEY when FIREBASE_WEB_API_KEY is unset.
# FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here

# HMAC secret for Option B billing link (min 16 chars). Required when FIREBASE_SERVICE_ACCOUNT_JSON is not set.
SUBSCRIPTION_LINK_SIGNING_SECRET=generate_a_long_random_string_here

# Firebase Admin JSON — optional. When set, webhooks + link write Firestore via Admin SDK directly.
# When blocked by org policy, omit these and deploy firestore.rules so the client can merge billing after link.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# Local Stripe dev proxy (optional)
# STRIPE_DEV_PROXY=1
# STRIPE_DEV_PORT=8787
