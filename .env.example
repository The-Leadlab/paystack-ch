# =========================
# Client (Vite) variables
# =========================

# Gemini server-side only. Never expose this as VITE_*.
GEMINI_API_KEY=your_server_only_gemini_api_key_here
# Optional hardening controls
# GEMINI_ALLOWED_MODELS=gemini-2.5-flash,gemini-2.5-flash-image
# GEMINI_RATE_LIMIT_MAX=30
# GEMINI_MAX_REQUEST_BYTES=18874368

# Firebase Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional client toggles
VITE_SUBSCRIPTION_ENABLED=true
# Comma-separated UIDs or emails that skip subscription enforcement (admin / legacy testers)
# VITE_SUBSCRIPTION_BYPASS_UIDS=firebaseUid1,firebaseUid2
VITE_SUBSCRIPTION_BYPASS_EMAILS=ali@the-leadlab.com,kara@the-leadlab.com
# VITE_API_BASE_URL=https://your-api-domain.com
# Client model hints. The server allowlist still decides what is accepted.
# VITE_GEMINI_MODEL=gemini-2.5-flash
# VITE_GEMINI_BANK_MODEL=gemini-2.5-flash
# VITE_GEMINI_CHAT_MODEL=gemini-2.5-flash
# VITE_GEMINI_MAX_OUTPUT_TOKENS=8192
# VITE_DOCUMENT_PROCESSING_TIMEOUT_MS=240000
# VITE_DOCUMENT_PROCESSING_CONCURRENCY=3


# =========================
# Server variables (Stripe/API)
# =========================

PUBLIC_APP_URL=https://paystack.ch

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: Stripe test mode keys (guest JSON `stripeTest: true`, `/api/stripe-test/*` on the Node server).
# Use Stripe Dashboard (Test mode) prices: price_... IDs in STRIPE_TEST_PRICE_*.
STRIPE_TEST_SECRET_KEY=
STRIPE_TEST_WEBHOOK_SECRET=
STRIPE_TEST_PRICE_STARTER=
STRIPE_TEST_PRICE_BUSINESS=
STRIPE_TEST_PRICE_UNLIMITED=
# STRIPE_TEST_PRICE_ID=
# Stripe recurring prices. Prefer real Stripe Price IDs from Dashboard (price_1ABC...).
# Numeric CHF amounts are also supported and converted to monthly Checkout price_data.
STRIPE_PRICE_STARTER=29
STRIPE_PRICE_BUSINESS=59
STRIPE_PRICE_UNLIMITED=499
# STRIPE_TRIAL_DAYS=7
# STRIPE_CORS_ORIGIN=https://paystack.ch

# Firebase Admin service account JSON (single-line JSON string; keep out of frontend env)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project","private_key_id":"placeholder","private_key":"placeholder_private_key","client_email":"firebase-adminsdk@example.iam.gserviceaccount.com","client_id":"placeholder","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"placeholder"}

# Local Stripe dev proxy (optional)
# STRIPE_DEV_PROXY=1
# STRIPE_DEV_PORT=8787
